<script>
// ===== ERC-8183 合约地址 (BSC Mainnet) =====
const COMMERCE='0xea4daa3100a767e86fded867729ae7446476eba6';
const ROUTER='0x51895229e12f9876011789b04f8698af06ccd6da';
const POLICY='0x9c01845705b3078aa2e8cff7520a6376fd766de5';
const USDT='0x55d398326f99059fF775485246999027B3197955';
const PROVIDER='0x5460BeEd186E1b3786713AFf6eD71962C1CBE931';

let sel=null,prov,jobId=null;

// ===== ERC-8183 ABI — 来自BNBAgent SDK官方 + AgentEscrow参考 =====
// 参照 bnbagent-sdk/abis/AgenticCommerce.json 提取
const COMMERCE_ABI=[
  // createJob: SDK happy.py 第1步 — 创建托管订单
  'function createJob(address provider, address evaluator, uint256 expiredAt, string description, address hook) returns (uint256 jobId)',
  // setBudget: SDK happy.py 第3步 — 设定托管金额
  'function setBudget(uint256 jobId, uint256 amount, bytes optParams)',
  // fund: SDK happy.py 第5步 — 资金锁定进合约托管
  'function fund(uint256 jobId, uint256 expectedBudget, bytes optParams)',
  // paymentToken: 查询合约接受的支付代币
  'function paymentToken() view returns (address)',
  // getJob: 查询订单状态
  'function getJob(uint256 jobId) view returns (tuple(uint256 id, address client, address provider, address evaluator, string description, uint256 budget, uint256 expiredAt, uint8 status, address hook, uint256 submittedAt, bytes32 deliverable))'
];
const ROUTER_ABI=[
  // registerJob: SDK happy.py 第2步 — 绑定保障策略
  'function registerJob(uint256 jobId, address policy)'
];
const ERC20_ABI=[
  // approve: SDK happy.py 第4步 — 授权合约划转USDT
  'function approve(address spender, uint256 value) returns (bool)',
  // allowance: 检查已有授权额度，避免重复授权
  'function allowance(address owner, address spender) view returns (uint256)',
  'function balanceOf(address account) view returns (uint256)'
];

// ===== ethers.js 接口初始化 =====
let commerceIface, routerIface, erc20Iface;
try {
  commerceIface = new ethers.utils.Interface(COMMERCE_ABI);
  routerIface = new ethers.utils.Interface(ROUTER_ABI);
  erc20Iface = new ethers.utils.Interface(ERC20_ABI);
} catch(e) { console.error('ethers.js init failed:', e); }

// ===== 工具函数 =====
function fp(){return window.tokenpocket?.ethereum||window.ethereum||window.web3?.currentProvider||null}

// USDT是18位小数（BSC上的USDT）
function tw(u){const p=u.toString().split('.');return ethers.BigNumber.from(p[0]+(p[1]||'').padEnd(18,'0').substring(0,18))}

function sc(el){
  document.querySelectorAll('.card').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');sel=parseFloat(el.dataset.amt);
  const b=document.getElementById('buyBtn');b.disabled=false;
  b.textContent='合约托管支付 '+sel+' USDT';
}

function gs(n){
  for(let i=1;i<=3;i++){
    document.getElementById('d'+i).className=n>i?'dt d':n===i?'dt a':'dt';
  }
  document.getElementById('p1').className=n===1?'':'h';
  document.getElementById('p2').className=n===2?'':'h';
  document.getElementById('p3').className=n===3?'':'h';
}

// 更新5步进度条
function updateStep(done, active){
  for(let i=1;i<=5;i++){
    const el=document.getElementById('s'+i);
    el.className = i<=done ? 'step done' : i===active ? 'step active' : 'step';
  }
}

function setStatus(html){const s=document.getElementById('st');s.className='st on';s.innerHTML=html;}
function setError(msg){setStatus('<span class="err">❌</span> '+msg);}

// ===== 发送交易并等待链上确认 =====
async function sendTx(txData, stepLabel){
  const accounts = await prov.request({method:'eth_requestAccounts'});
  const from = accounts[0];
  const txHash = await prov.request({
    method:'eth_sendTransaction',
    params:[{from, to:txData.to, data:txData.data, value:'0x0'}]
  });
  setStatus('⏳ '+stepLabel+' 确认中...<br><a class="lk" href="https://bscscan.com/tx/'+txHash+'" target="_blank">'+txHash.slice(0,18)+'...</a>');
  // 轮询等待交易确认（最多3分钟）
  for(let i=0;i<60;i++){
    await new Promise(r=>setTimeout(r,3000));
    const rc=await prov.request({method:'eth_getTransactionReceipt',params:[txHash]});
    if(rc){
      if(rc.status==='0x1') return {txHash, receipt:rc};
      throw new Error(stepLabel+' 交易失败');
    }
  }
  throw new Error(stepLabel+' 确认超时');
}

// ===== 从createJob回执中解析JobCreated事件获取jobId =====
// 事件签名: JobCreated(uint256,address,address,address,uint256,string,address)
function parseJobId(receipt){
  if(!receipt || !receipt.logs) return null;
  const topic0 = ethers.utils.id('JobCreated(uint256,address,address,address,uint256,string,address)');
  for(const log of receipt.logs){
    if(log.topics && log.topics[0]===topic0){
      // topics[1] = jobId (uint256, indexed)
      return ethers.BigNumber.from(log.topics[1]).toNumber();
    }
  }
  return null;
}

// ===== 初始化：连接钱包 =====
async function init(){
  const wi=document.getElementById('wi');
  await new Promise(r=>setTimeout(r,1000));
  prov=fp();
  if(!prov){
    wi.innerHTML='❌ 未检测到钱包<br><span style="font-size:11px;color:#999">请用TP钱包/Trust Wallet/MetaMask的DApp浏览器打开</span><br><span style="font-size:11px;color:#999">也可先浏览套餐内容</span>';
    document.getElementById('cards').style.display='block';
    return;
  }
  try{
    const a=await prov.request({method:'eth_requestAccounts'});
    if(!a?.length) throw 0;
    let c=await prov.request({method:'eth_chainId'});
    if(c!=='0x38'){
      try{await prov.request({method:'wallet_switchEthereumChain',params:[{chainId:'0x38'}]})}
      catch(e){await prov.request({method:'wallet_addEthereumChain',params:[{chainId:'0x38',chainName:'BNB Smart Chain',nativeCurrency:{name:'BNB',symbol:'BNB',decimals:18},rpcUrls:['https://bsc.publicnode.com'],blockExplorerUrls:['https://bscscan.com']}]})}
      c=await prov.request({method:'eth_chainId'});
    }
    wi.innerHTML='✅ <b>'+a[0].slice(0,6)+'...'+a[0].slice(38)+'</b>'+(c==='0x38'?' · 已连接':' · ⚠️请切换网络');
    document.getElementById('cards').style.display='block';
    document.getElementById('buyBtn').style.display='block';
    document.getElementById('dots').style.display='flex';
    document.getElementById('stepProgress').style.display='flex';
  }catch(e){
    wi.innerHTML='❌ 连接失败，请刷新';
    document.getElementById('cards').style.display='block';
  }
}

// ===== ERC-8183 5步合约托管支付 =====
// 严格按照 BNBAgent SDK happy.py 的5步流程：
// createJob → registerJob → setBudget → approve+fund
async function erc8183_pay(){
  if(!sel) return;
  const b=document.getElementById('buyBtn');
  b.disabled=true;
  updateStep(0,0);

  const amountWei = tw(sel); // USDT 18位小数
  const expiredAt = Math.floor(Date.now()/1000) + 7*24*3600; // 7天过期
  const description = 'Fly GEO服务 - '+sel+' USDT套餐';

  try{
    // ===== 第1步：createJob — 创建托管订单 =====
    // 对应SDK: client.create_job(provider=..., expired_at=..., description=...)
    updateStep(0,1);
    b.textContent='第1步/5：创建订单...';
    setStatus('⏳ 正在创建托管订单，请在钱包中确认...<br><span style="font-size:11px;color:#999">这会创建一个合约托管订单，你的钱还在你口袋</span>');

    const createData = commerceIface.encodeFunctionData('createJob',[
      PROVIDER,       // provider: Fly服务方地址
      ROUTER,         // evaluator: EvaluatorRouter合约
      expiredAt,      // expiredAt: 7天后过期
      description,    // description: 订单描述
      ROUTER          // hook: Router合约（SDK默认evaluator=hook=Router）
    ]);
    const step1 = await sendTx({to:COMMERCE, data:createData}, '创建订单');
    jobId = parseJobId(step1.receipt);
    if(!jobId){
      throw new Error('无法获取订单号。交易已上链：<a class="lk" href="https://bscscan.com/tx/'+step1.txHash+'" target="_blank">查看</a>');
    }
    console.log('✅ Job created, jobId=', jobId);
    updateStep(1,0);

    // ===== 第2步：registerJob — 注册保障策略 =====
    // 对应SDK: client.register_job(job_id)  → binds OptimisticPolicy
    updateStep(1,2);
    b.textContent='第2步/5：注册保障...';
    setStatus('✅ 订单已创建 (Job #'+jobId+')<br>⏳ 正在注册保障策略，请在钱包中确认...<br><span style="font-size:11px;color:#999">这会让订单获得争议退款保障</span>');

    const registerData = routerIface.encodeFunctionData('registerJob',[jobId, POLICY]);
    await sendTx({to:ROUTER, data:registerData}, '注册保障');
    console.log('✅ Job registered to OptimisticPolicy');
    updateStep(2,0);

    // ===== 第3步：setBudget — 设定托管金额 =====
    // 对应SDK: client.set_budget(job_id, budget)
    updateStep(2,3);
    b.textContent='第3步/5：设定托管金额...';
    setStatus('✅ 保障策略已注册<br>⏳ 正在设定托管金额 ('+sel+' USDT)，请在钱包中确认...<br><span style="font-size:11px;color:#999">设定你同意托管的金额上限</span>');

    const setBudgetData = commerceIface.encodeFunctionData('setBudget',[jobId, amountWei, '0x']);
    await sendTx({to:COMMERCE, data:setBudgetData}, '设定托管金额');
    console.log('✅ Budget set:', sel, 'USDT');
    updateStep(3,0);

    // ===== 第4步：approve — 授权合约划转USDT =====
    // 对应SDK: client.fund() 内部自动检测allowance并approve
    updateStep(3,4);
    b.textContent='第4步/5：授权托管...';
    setStatus('✅ 托管金额已设定<br>⏳ 正在授权USDT托管，请在钱包中确认...<br><span style="font-size:11px;color:#999">授权合约从你的钱包划转USDT（不会自动扣款）</span>');

    // 先检查现有授权额度（SDK的floor-based策略）
    const accounts = await prov.request({method:'eth_requestAccounts'});
    const owner = accounts[0];
    const allowanceData = erc20Iface.encodeFunctionData('allowance',[owner, COMMERCE]);
    const allowanceResult = await prov.request({
      method:'eth_call',
      params:[{to:USDT, data:allowanceData},'latest']
    });
    const currentAllowance = ethers.BigNumber.from(allowanceResult);

    // SDK默认approve_floor=100 USDT，我们用同样的策略
    if(currentAllowance.lt(amountWei)){
      const floor = ethers.BigNumber.from('100000000000000000000'); // 100 USDT
      const approveAmount = amountWei.gt(floor) ? amountWei : floor;
      const approveData = erc20Iface.encodeFunctionData('approve',[COMMERCE, approveAmount]);
      await sendTx({to:USDT, data:approveData}, '授权托管');
      console.log('✅ USDT approved:', ethers.utils.formatUnits(approveAmount, 18));
    } else {
      console.log('✅ Sufficient allowance already:', ethers.utils.formatUnits(currentAllowance, 18));
      setStatus('✅ 已有足够授权额度，跳过授权步骤');
    }
    updateStep(4,0);

    // ===== 第5步：fund — 资金锁定进合约托管 =====
    // 对应SDK: client.fund(job_id, budget) — 钱从用户钱包转入合约
    updateStep(4,5);
    b.textContent='第5步/5：资金锁定...';
    setStatus('✅ 授权完成<br>⏳ 正在锁定资金到托管合约，请在钱包中确认...<br><span style="font-size:11px;color:#999">资金锁定后，服务完成才会释放给商家</span>');

    const fundData = commerceIface.encodeFunctionData('fund',[jobId, amountWei, '0x']);
    const step5 = await sendTx({to:COMMERCE, data:fundData}, '资金锁定');
    console.log('✅ Funds escrowed! Job is now FUNDED');
    updateStep(5,0);

    // ===== 全部5步完成！ =====
    setStatus('🎉 托管支付完成！<br>订单号：<b>FLY-'+jobId+'</b><br>资金已锁定，服务完成后自动释放<br><a class="lk" href="https://bscscan.com/tx/'+step5.txHash+'" target="_blank">查看托管交易 →</a>');
    b.textContent='✅ 托管完成，请填写店铺信息';
    b.disabled=false;
    b.onclick=function(){gs(2);};

  }catch(e){
    let m=e.message||String(e);
    if(/denied|reject|cancel/i.test(m)) m='您取消了确认';
    else if(/insufficient/i.test(m)) m='余额不足';
    else if(/交易失败/.test(m)) m=m;
    else m='操作失败：'+m.slice(0,100);
    setError(m);
    b.disabled=false;
    b.textContent='重新托管支付 '+sel+' USDT';
    b.onclick=function(){erc8183_pay();};
  }
}

// ===== 提交店铺信息（存证上链） =====
async function go(){
  const n=document.getElementById('fN').value,t=document.getElementById('fT').value;
  if(!n||!t){alert('请填写店铺名称和类型');return}
  const oid='FLY-'+(jobId||Date.now().toString(36).toUpperCase());
  const d=JSON.stringify({id:oid,jobId:jobId,amt:sel,shop:{n,t,a:document.getElementById('fA').value,p:document.getElementById('fP').value},ts:Date.now()});
  try{
    const a=await prov.request({method:'eth_requestAccounts'}),f=a[0];
    // 将店铺信息编码上链存证
    const hx='0x'+Array.from(new TextEncoder().encode('FLY:'+d)).map(b=>b.toString(16).padStart(2,'0')).join('');
    const otx=await prov.request({method:'eth_sendTransaction',params:[{from:f,to:f,data:hx,value:'0x0'}]});
    gs(3);
    document.getElementById('rP').textContent=otx?otx.slice(0,18)+'...':'';
    document.getElementById('rP').href=otx?'https://bscscan.com/tx/'+otx:'#';
    document.getElementById('rI').textContent=oid;
    document.getElementById('rJ').textContent=jobId||'—';
    document.getElementById('rL').href='https://bscscan.com/address/'+COMMERCE;
    document.getElementById('diagBtn').style.display='inline-block';
  }catch(e){
    // 钱包不可用时本地保存
    let or=JSON.parse(localStorage.getItem('fly_orders')||'[]');
    or.push({id:oid,jobId,d});localStorage.setItem('fly_orders',JSON.stringify(or));
    gs(3);
    document.getElementById('rP').textContent='本地记录';
    document.getElementById('diagBtn').style.display='inline-block';
    document.getElementById('rI').textContent=oid;
    document.getElementById('rJ').textContent=jobId||'—';
    document.getElementById('rL').href='https://bscscan.com/address/'+COMMERCE;
  }
}

// ===== 调用Agent Server获取AI诊断报告 =====
async function fetchDiagnosis(){
  const btn=document.getElementById('diagBtn');
  const div=document.getElementById('diagReport');
  btn.disabled=true; btn.textContent='AI正在生成诊断报告...';
  const name=document.getElementById('fN').value||'';
  const type=document.getElementById('fT').value||'';
  const addr=document.getElementById('fA').value||'';
  const pkgMap={'9.9':'starter','59':'basic','299':'pro','999':'enterprise'};
  const pkg=pkgMap[sel]||'starter';
  try{
    const r=await fetch('https://fly-agent-server.vercel.app/geo-diagnosis?store_name='+encodeURIComponent(name)+'&industry='+encodeURIComponent(type)+'&address='+encodeURIComponent(addr)+'&package_type='+pkg);
    if(!r.ok) throw new Error('API返回'+r.status);
    const d=await r.json();
    if(d.success&&d.report){
      div.style.display='block'; div.textContent=d.report;
      btn.textContent='✅ 诊断报告已生成'; btn.disabled=false;
    } else { throw new Error(d.detail||'生成失败'); }
  }catch(e){
    div.style.display='block'; div.textContent='⚠️ 诊断生成失败：'+e.message+'\n\n请稍后访问 fly-agent.xyz 获取报告';
    btn.textContent='重新获取'; btn.disabled=false;
  }
}

init();
</script>
</body>
</html>
